<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="12dp">

    <!-- Type + Time row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_reassessment_type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SpO2 Reassessment"
            android:textColor="#1A1C1E"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18 Mar, 00:15"
            android:textColor="#94A3B8"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Values Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <!-- SpO2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SpO₂"
                android:textColor="#94A3B8"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_spo2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="92%"
                android:textColor="#1A1C1E"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Respiratory Rate -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resp Rate"
                android:textColor="#94A3B8"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_respiratory_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="22 /min"
                android:textColor="#1A1C1E"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Heart Rate -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heart Rate"
                android:textColor="#94A3B8"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_heart_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="88 bpm"
                android:textColor="#1A1C1E"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ABG Values (shown only if present) -->
    <TextView
        android:id="@+id/tv_abg_values"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="ABG: pH 7.35, PaO2 65"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Remarks (shown only if present) -->
    <TextView
        android:id="@+id/tv_remarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Remarks: Patient stable"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:textStyle="italic"
        android:visibility="gone" />

    <!-- Entered by label -->
    <TextView
        android:id="@+id/tv_entered_by"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Entered by: Staff"
        android:textColor="#10B981"
        android:textSize="11sp"
        android:textStyle="italic" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#F1F5F9" />
</LinearLayout>
